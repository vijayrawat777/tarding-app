@page "/"
@rendermode InteractiveServer

<PageTitle>Home - Algo Trading System</PageTitle>

<div style="background: linear-gradient(135deg, #0d1117 0%, #161b22 100%); color: #e6edf3; min-height: 100vh; padding: 40px 20px;">
    <div class="container">
        <!-- HERO SECTION -->
        <div style="text-align: center; margin-bottom: 60px; padding: 40px 0;">
            <h1 style="font-size: 3.5rem; font-weight: bold; margin-bottom: 20px; color: #58a6ff;">
                📊 Algo Trading System
            </h1>
            <p style="font-size: 1.3rem; color: #8b949e; margin-bottom: 30px;">
                Automated Options Trading Platform for Indian Stock Market
            </p>
            <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
                <a href="/trading-dashboard" class="btn btn-primary" style="padding: 12px 30px; font-size: 1rem;">
                    🚀 Start Trading
                </a>
                <a href="/backtest" class="btn btn-outline-primary" style="padding: 12px 30px; font-size: 1rem;">
                    📈 Test Strategy
                </a>
            </div>
        </div>

        <!-- FEATURES GRID -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-bottom: 60px;">
            
            <!-- FEATURE 1 -->
            <div style="background: #161b22; border: 1px solid #30363d; border-radius: 12px; padding: 30px; transition: transform 0.3s, border-color 0.3s;">
                <div style="font-size: 2.5rem; margin-bottom: 15px;">📊</div>
                <h3 style="color: #58a6ff; margin-bottom: 15px; font-size: 1.3rem;">Trading Dashboard</h3>
                <p style="color: #8b949e; line-height: 1.6;">
                    Real-time market analysis, options chain visualization, and automated trading controls.
                </p>
                <a href="/trading-dashboard" style="color: #58a6ff; text-decoration: none; font-weight: 600; margin-top: 20px; display: inline-block;">
                    Go to Dashboard →
                </a>
            </div>

            <!-- FEATURE 2 -->
            <div style="background: #161b22; border: 1px solid #30363d; border-radius: 12px; padding: 30px; transition: transform 0.3s, border-color 0.3s;">
                <div style="font-size: 2.5rem; margin-bottom: 15px;">⚡</div>
                <h3 style="color: #58a6ff; margin-bottom: 15px; font-size: 1.3rem;">Option Chain Analysis</h3>
                <p style="color: #8b949e; line-height: 1.6;">
                    Detailed options chain with Greeks (IV, Delta, Gamma, Theta, Vega) and bid/ask spreads.
                </p>
                <a href="/option-chain" style="color: #58a6ff; text-decoration: none; font-weight: 600; margin-top: 20px; display: inline-block;">
                    View Options →
                </a>
            </div>

            <!-- FEATURE 3 -->
            <div style="background: #161b22; border: 1px solid #30363d; border-radius: 12px; padding: 30px; transition: transform 0.3s, border-color 0.3s;">
                <div style="font-size: 2.5rem; margin-bottom: 15px;">🔄</div>
                <h3 style="color: #58a6ff; margin-bottom: 15px; font-size: 1.3rem;">Strategy Backtesting</h3>
                <p style="color: #8b949e; line-height: 1.6;">
                    Test trading strategies on historical data with detailed performance metrics.
                </p>
                <a href="/backtest" style="color: #58a6ff; text-decoration: none; font-weight: 600; margin-top: 20px; display: inline-block;">
                    Start Backtest →
                </a>
            </div>
        </div>

        <!-- TRADING STRATEGIES -->
        <div style="background: #161b22; border: 1px solid #30363d; border-radius: 12px; padding: 40px; margin-bottom: 40px;">
            <h2 style="color: #58a6ff; margin-bottom: 30px; font-size: 2rem;">🎯 Supported Strategies</h2>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
                <div style="background: #0d1117; padding: 20px; border-radius: 8px; border-left: 3px solid #3fb950;">
                    <h4 style="color: #3fb950; margin-bottom: 10px;">📈 Bullish Strategies</h4>
                    <ul style="color: #8b949e; list-style: none; padding: 0; margin: 0;">
                        <li>✓ Bull Call Spread</li>
                        <li>✓ Bull Put Spread</li>
                        <li>✓ Covered Call</li>
                    </ul>
                </div>

                <div style="background: #0d1117; padding: 20px; border-radius: 8px; border-left: 3px solid #f85149;">
                    <h4 style="color: #f85149; margin-bottom: 10px;">📉 Bearish Strategies</h4>
                    <ul style="color: #8b949e; list-style: none; padding: 0; margin: 0;">
                        <li>✓ Bear Call Spread</li>
                        <li>✓ Bear Put Spread</li>
                        <li>✓ Protective Put</li>
                    </ul>
                </div>

                <div style="background: #0d1117; padding: 20px; border-radius: 8px; border-left: 3px solid #d29922;">
                    <h4 style="color: #d29922; margin-bottom: 10px;">🎯 Neutral Strategies</h4>
                    <ul style="color: #8b949e; list-style: none; padding: 0; margin: 0;">
                        <li>✓ Straddle</li>
                        <li>✓ Strangle</li>
                        <li>✓ Iron Condor</li>
                    </ul>
                </div>

                <div style="background: #0d1117; padding: 20px; border-radius: 8px; border-left: 3px solid #58a6ff;">
                    <h4 style="color: #58a6ff; margin-bottom: 10px;">🤖 Algorithms</h4>
                    <ul style="color: #8b949e; list-style: none; padding: 0; margin: 0;">
                        <li>✓ EMA Crossover</li>
                        <li>✓ RSI Strategy</li>
                        <li>✓ MACD Strategy</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- KEY STATS -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px;">
            <div style="background: #161b22; border: 1px solid #30363d; border-radius: 12px; padding: 30px; text-align: center;">
                <div style="font-size: 2.5rem; color: #3fb950; font-weight: bold;">20+</div>
                <div style="color: #8b949e; margin-top: 10px;">Supported Stocks</div>
            </div>
            <div style="background: #161b22; border: 1px solid #30363d; border-radius: 12px; padding: 30px; text-align: center;">
                <div style="font-size: 2.5rem; color: #58a6ff; font-weight: bold;">9</div>
                <div style="color: #8b949e; margin-top: 10px;">Trading Strategies</div>
            </div>
            <div style="background: #161b22; border: 1px solid #30363d; border-radius: 12px; padding: 30px; text-align: center;">
                <div style="font-size: 2.5rem; color: #f85149; font-weight: bold;">Paper</div>
                <div style="color: #8b949e; margin-top: 10px;">Trading Mode</div>
            </div>
            <div style="background: #161b22; border: 1px solid #30363d; border-radius: 12px; padding: 30px; text-align: center;">
                <div style="font-size: 2.5rem; color: #d29922; font-weight: bold;">Real-time</div>
                <div style="color: #8b949e; margin-top: 10px;">Updates</div>
            </div>
        </div>

        <!-- GETTING STARTED -->
        <div style="background: #161b22; border: 2px solid #58a6ff; border-radius: 12px; padding: 40px; text-align: center;">
            <h2 style="color: #58a6ff; margin-bottom: 20px; font-size: 1.8rem;">🚀 Getting Started</h2>
            <ol style="color: #8b949e; text-align: left; max-width: 600px; margin: 0 auto; line-height: 2;">
                <li>Navigate to <strong style="color: #e6edf3;">Trading Dashboard</strong> for real-time options analysis</li>
                <li>Select your preferred <strong style="color: #e6edf3;">trading strategy</strong> (Bullish/Bearish/Neutral)</li>
                <li>Configure auto-trading parameters or <strong style="color: #e6edf3;">place manual orders</strong></li>
                <li>Monitor live trade logs and performance metrics</li>
                <li>Use <strong style="color: #e6edf3;">Backtest</strong> to validate strategies before live trading</li>
            </ol>
        </div>

        <!-- FOOTER -->
        <footer style="text-align: center; margin-top: 60px; padding-top: 30px; border-top: 1px solid #30363d; color: #8b949e;">
            <p style="margin: 0; font-size: 0.9rem;">
                © 2026 Algo Trading System | Built for Indian Stock Market | Paper Trading Mode
            </p>
        </footer>
    </div>
</div>

<style>
    .btn {
        display: inline-block;
        padding: 10px 20px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s;
        border: none;
        cursor: pointer;
    }

    .btn-primary {
        background-color: #58a6ff;
        color: #0d1117;
    }

    .btn-primary:hover {
        background-color: #79c0ff;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(88, 166, 255, 0.3);
    }

    .btn-outline-primary {
        border: 2px solid #58a6ff;
        color: #58a6ff;
        background-color: transparent;
    }

    .btn-outline-primary:hover {
        background-color: #58a6ff;
        color: #0d1117;
        transform: translateY(-2px);
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
    }

    [style*="border-radius: 12px"]:hover {
        border-color: #58a6ff;
        transition: border-color 0.3s;
    }
</style>
