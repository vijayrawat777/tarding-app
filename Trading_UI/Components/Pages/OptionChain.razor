@page "/option-chain"
@inject IOptionChainService OptionChainService
@rendermode InteractiveServer

<style>
    .option-chain-container {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    }

    .option-chain-header {
        background: linear-gradient(135deg, #0f3460 0%, #16213e 100%);
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 25px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
    }

    .option-chain-header h2 {
        color: #00d4ff;
        margin: 0;
        font-weight: 700;
        font-size: 28px;
        letter-spacing: 1px;
    }

    .filter-section {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr 1fr;
        gap: 15px;
        margin-bottom: 25px;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
    }

    .filter-group label {
        color: #a0aec0;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .filter-group select,
    .filter-group input {
        background: #0f3460 !important;
        border: 2px solid #2a5298 !important;
        color: #fff !important;
        padding: 10px 12px;
        border-radius: 6px;
        font-size: 14px;
        transition: all 0.3s ease;
    }

    .filter-group select:focus,
    .filter-group input:focus {
        outline: none;
        border-color: #00d4ff !important;
        box-shadow: 0 0 10px rgba(0, 212, 255, 0.3);
    }

    .load-btn {
        background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
        border: none;
        color: #000;
        font-weight: 700;
        font-size: 14px;
        padding: 10px 24px;
        border-radius: 6px;
        align-self: flex-end;
        transition: all 0.3s ease;
        cursor: pointer;
        text-transform: uppercase;
    }

    .load-btn:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(0, 212, 255, 0.4);
    }

    .load-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .vix-section {
        background: rgba(0, 212, 255, 0.1);
        border-left: 4px solid #00d4ff;
        padding: 15px;
        border-radius: 6px;
        margin-bottom: 20px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 15px;
    }

    .vix-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .vix-label {
        color: #a0aec0;
        font-size: 12px;
    }

    .vix-value {
        color: #00d4ff;
        font-weight: 700;
        font-size: 16px;
    }

    .scroll-table {
        overflow-x: auto;
        border-radius: 8px;
    }

    .option-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
        font-size: 12px;
    }

    .option-table thead {
        background: #0f3460;
        position: sticky;
        top: 0;
    }

    .option-table th {
        padding: 12px 8px;
        text-align: center;
        color: #a0aec0;
        font-weight: 600;
        font-size: 11px;
        text-transform: uppercase;
        border-bottom: 2px solid #2a5298;
    }

    .call-header {
        color: #4caf50;
    }

    .put-header {
        color: #f44336;
    }

    .strike-header {
        color: #00d4ff;
    }

    .option-table tbody tr {
        border-bottom: 1px solid #2a5298;
        transition: background 0.2s ease;
    }

    .option-table tbody tr:hover {
        background: rgba(0, 212, 255, 0.05);
    }

    .option-table td {
        padding: 10px 8px;
        text-align: center;
        color: #cbd5e0;
    }

    .greek-cell {
        font-size: 10px;
        line-height: 1.4;
    }

    .strike-cell {
        font-weight: 700;
        font-size: 13px;
        color: #00d4ff;
        background: rgba(0, 212, 255, 0.1);
    }

    .call-cell {
        color: #4caf50;
    }

    .put-cell {
        color: #f44336;
    }

    .oi-cell {
        font-size: 11px;
        color: #90caf9;
    }

    .status-message {
        padding: 15px 20px;
        border-radius: 6px;
        margin-bottom: 20px;
        font-weight: 500;
        display: flex;
        gap: 10px;
    }

    .status-success {
        background: rgba(76, 175, 80, 0.2);
        color: #4caf50;
        border: 1px solid #4caf50;
    }

    .status-error {
        background: rgba(244, 67, 54, 0.2);
        color: #f44336;
        border: 1px solid #f44336;
    }

    .no-data {
        text-align: center;
        padding: 40px 20px;
        color: #a0aec0;
        font-size: 16px;
    }

    @@media (max-width: 1400px) {
        .filter-section { grid-template-columns: 1fr 1fr; }
    }

    @@media (max-width: 768px) {
        .filter-section { grid-template-columns: 1fr; }
        .option-table { font-size: 9px; }
        .option-table td, .option-table th { padding: 6px 4px; }
    }
</style>

<div class="option-chain-container">
    <div class="option-chain-header">
        <h2>📊 Options Chain Analysis</h2>
    </div>

    <div class="filter-section">
        <div class="filter-group">
            <label>Symbol</label>
            <select @bind="SelectedSymbol">
                <option value="NIFTY">Nifty 50</option>
                <option value="NIFTYBANK">Nifty Bank</option>
                <option value="TCS">TCS</option>
                <option value="INFY">Infosys</option>
                <option value="RELIANCE">Reliance</option>
                <option value="HDFC">HDFC Bank</option>
                <option value="ICICI">ICICI Bank</option>
            </select>
        </div>
        <div class="filter-group">
            <label>Expiry Date</label>
            <select @bind="SelectedExpiry">
                @foreach (var exp in AvailableExpiries)
                {
                    <option value="@exp">@exp</option>
                }
            </select>
        </div>
        <div class="filter-group">
            <label>Filter Strikes</label>
            <input type="text" placeholder="Search strikes..." @bind="SearchText" />
        </div>
        <div class="filter-group">
            <button class="load-btn" @onclick="LoadOptionChain" disabled="@IsLoading">
                @(IsLoading ? "⏳ Loading..." : "🔄 Load Chain")
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(StatusMessage))
    {
        <div class="status-message @(IsError ? "status-error" : "status-success")">
            @(IsError ? "⚠️" : "✅") @StatusMessage
        </div>
    }

    @if (OptionChainData?.Count > 0)
    {
        @if (!string.IsNullOrEmpty(VIXText))
        {
            <div class="vix-section">
                <div class="vix-item">
                    <span class="vix-label">📈 INDIAVIX</span>
                    <span class="vix-value">@VIXText</span>
                </div>
                <div class="vix-item">
                    <span class="vix-label">📊 CALL OI</span>
                    <span class="vix-value">@CallOIText</span>
                </div>
                <div class="vix-item">
                    <span class="vix-label">📊 PUT OI</span>
                    <span class="vix-value">@PutOIText</span>
                </div>
            </div>
        }

        <div class="scroll-table">
            <table class="option-table">
                <thead>
                    <tr>
                        <th colspan="4" class="call-header">📈 CALL OPTIONS</th>
                        <th colspan="1" class="strike-header">⭐ STRIKE</th>
                        <th colspan="4" class="put-header">📉 PUT OPTIONS</th>
                    </tr>
                    <tr>
                        <th>Bid</th>
                        <th>Ask</th>
                        <th>Greeks</th>
                        <th>OI</th>
                        <th class="strike-header">Price</th>
                        <th>OI</th>
                        <th>Greeks</th>
                        <th>Bid</th>
                        <th>Ask</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var data in FilteredOptionChainData)
                    {
                        <tr>
                            <td class="call-cell">@data.CallBid.ToString("F2")</td>
                            <td class="call-cell">@data.CallAsk.ToString("F2")</td>
                            <td class="greek-cell">
                                Δ@(data.CallDelta?.ToString("F2") ?? "-")<br/>
                                Θ@(data.CallTheta?.ToString("F1") ?? "-")<br/>
                                IV@(data.CallIV?.ToString("F0") ?? "-")
                            </td>
                            <td class="oi-cell">@FormatNumber(data.CallOpenInterest)</td>
                            <td class="strike-cell">@data.StrikePrice.ToString("F0")</td>
                            <td class="oi-cell">@FormatNumber(data.PutOpenInterest)</td>
                            <td class="greek-cell">
                                Δ@(data.PutDelta?.ToString("F2") ?? "-")<br/>
                                Θ@(data.PutTheta?.ToString("F1") ?? "-")<br/>
                                IV@(data.PutIV?.ToString("F0") ?? "-")
                            </td>
                            <td class="put-cell">@data.PutBid.ToString("F2")</td>
                            <td class="put-cell">@data.PutAsk.ToString("F2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div style="margin-top: 15px; color: #a0aec0; font-size: 12px;">
            Showing @FilteredOptionChainData.Count of @OptionChainData.Count strikes
        </div>
    }

    @if (!IsLoading && OptionChainData?.Count == 0)
    {
        <div class="no-data">
            <div style="font-size: 40px; margin-bottom: 15px;">📉</div>
            <div>Select a symbol and expiry date, then click "Load Chain"</div>
        </div>
    }
</div>

@code {
    private string SelectedSymbol = "NIFTY";
    private string SelectedExpiry = "";
    private string SearchText = "";
    private List<OptionChainData> OptionChainData = new();
    private List<string> AvailableExpiries = new();
    private bool IsLoading = false;
    private bool IsError = false;
    private string StatusMessage = "";
    private string VIXText = "";
    private string CallOIText = "";
    private string PutOIText = "";

    private List<OptionChainData> FilteredOptionChainData =>
        string.IsNullOrEmpty(SearchText)
            ? OptionChainData
            : OptionChainData.Where(x => x.StrikePrice.ToString().Contains(SearchText)).ToList();

    protected override async Task OnInitializedAsync()
    {
        SelectedExpiry = DateTime.Now.AddDays(7).ToString("yyyy-MM-dd");
        AvailableExpiries = new()
        {
            DateTime.Now.AddDays(7).ToString("yyyy-MM-dd"),
            DateTime.Now.AddDays(14).ToString("yyyy-MM-dd"),
            DateTime.Now.AddDays(21).ToString("yyyy-MM-dd")
        };
    }

    private string NormalizeSymbol(string symbol) => symbol switch
    {
        "NIFTY" => "NIFTY50",
        "NIFTYBANK" => "NIFTYBANK50",
        "TCS" => "TCS",
        "INFY" => "INFY",
        "RELIANCE" => "RELIANCE",
        "HDFC" => "HDFCBANK",
        "ICICI" => "ICICIBANK",
        _ => symbol
    };

    private async Task LoadOptionChain()
    {
        IsLoading = true;
        IsError = false;
        StatusMessage = "";
        OptionChainData.Clear();
        VIXText = "";
        CallOIText = "";
        PutOIText = "";

        try
        {
            var normalizedSymbol = NormalizeSymbol(SelectedSymbol);
            var result = await OptionChainService.GetOptionChainAsync(normalizedSymbol, SelectedExpiry);

            if (result.Success && result.Data?.Any() == true)
            {
                OptionChainData = result.Data.OrderBy(x => x.StrikePrice).ToList();
                StatusMessage = $"✓ Loaded {OptionChainData.Count} strikes for {SelectedSymbol}";
                IsError = false;

                if (result.VIXData != null)
                {
                    VIXText = result.VIXData.LTP.ToString("F2");
                }

                CallOIText = FormatNumber(result.TotalCallOI);
                PutOIText = FormatNumber(result.TotalPutOI);
            }
            else
            {
                StatusMessage = result.Message ?? "No data available";
                IsError = true;
            }
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
            IsError = true;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private string FormatNumber(long number)
    {
        if (number >= 1000000)
            return (number / 1000000.0).ToString("F1") + "M";
        if (number >= 1000)
            return (number / 1000.0).ToString("F1") + "K";
        return number.ToString();
    }
}

