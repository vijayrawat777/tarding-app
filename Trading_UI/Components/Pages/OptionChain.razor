    private string FormatNumber(long number)
    {
        if (number >= 1000000)
            return (number / 1000000.0).ToString("F1") + "M";
        if (number >= 1000)
            return (number / 1000.0).ToString("F1") + "K";
        return number.ToString();
    }

    // Helper Methods for Decision Making
    private string GetSpreadQuality(OptionDto option)
    {
        var spread = (option.AskPrice - option.BidPrice) / option.LastTradedPrice;
        if (spread < 0.01m) return "✅ EXCELLENT";
        if (spread < 0.03m) return "✅ GOOD";
        if (spread < 0.05m) return "⚠️ FAIR";
        return "❌ WIDE (AVOID)";
    }

    private string GetBreakevenPrice(OptionDto option)
    {
        var breakeven = option.Type == "Call"
            ? option.StrikePrice + option.AskPrice
            : option.StrikePrice - option.AskPrice;
        return $"${breakeven:F0}";
    }

    private string GetThetaImpact(OptionDto option)
    {
        var dailyLoss = (option.Theta ?? 0) * -1;
        return $"${dailyLoss:F4}/day (Time decay)";
    }

    private string GetDeltaInterpretation(decimal? delta)
    {
        if (delta == null) return "";
        var absDelta = Math.Abs(delta.Value);
        if (absDelta < 0.3m) return "Low Leverage";
        if (absDelta < 0.7m) return "Medium Leverage";
        return "High Leverage";
    }

    private string GetIVQuality(decimal? iv)
    {
        if (iv == null) return "";
        if (iv < 18m) return "LOW";
        if (iv < 25m) return "NORMAL";
        return "HIGH";
    }

    private string GetVolumeQuality(long volume)
    {
        if (volume > 50000) return "EXCELLENT";
        if (volume > 20000) return "GOOD";
        if (volume > 5000) return "FAIR";
        return "LOW";
    }

    private string GetSellRiskLevel(OptionDto option)
    {
        var distance = Math.Abs(option.StrikePrice - optionChainData!.UnderlyingPrice);
        if (distance > option.StrikePrice * 0.05m) return "SAFE (OTM)";
        if (distance > option.StrikePrice * 0.02m) return "MODERATE";
        return "HIGH (ITM)";
    }

