@page "/marketwatch"
@using Trading_UI.Services
@inject IFyersDataService FyersDataService
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Market Watch - Live Fyers Data</PageTitle>

<div class="container-fluid mt-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1>📊 Live Market Watch</h1>
            <p class="text-muted">Real-time data from Fyers API</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="alert alert-info">Loading market data...</div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            <strong>Error:</strong> @errorMessage
        </div>
    }
    else
    {
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card bg-light">
                    <div class="card-body">
                        <h5>Market Status: <strong>@(marketOpen ? "🟢 OPEN" : "🔴 CLOSED")</strong></h5>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            @foreach (var stock in stocks)
            {
                if (stock?.Data != null)
                {
                    <div class="col-md-4 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <h5>@stock.Data.Symbol</h5>
                                <p class="text-muted">@stock.Data.Name</p>
                                <h3>₹ @stock.Data.CurrentPrice.ToString("F2")</h3>
                                
                                <div class="row mt-3">
                                    <div class="col-6">
                                        <small>Change</small>
                                        <p style="color: @(stock.Data.ChangePercent > 0 ? "green" : "red")">
                                            @((stock.Data.ChangePercent > 0 ? "▲" : "▼")) 
                                            @stock.Data.Change.ToString("F2") (@stock.Data.ChangePercent.ToString("F2")%)
                                        </p>
                                    </div>
                                    <div class="col-6">
                                        <small>High/Low</small>
                                        <p>@stock.Data.DayHigh.ToString("F2") / @stock.Data.DayLow.ToString("F2")</p>
                                    </div>
                                </div>

                                <small>Updated: @stock.Data.LastUpdated.ToString("HH:mm:ss")</small>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    private List<StockQuoteResponse> stocks = new();
    private bool isLoading = true;
    private bool marketOpen = false;
    private string errorMessage = "";
    private Timer refreshTimer;

    private List<string> watchlistSymbols = new() { "TCS", "RELIANCE", "INFY", "HDFC", "WIPRO" };

    protected override async Task OnInitializedAsync()
    {
        await LoadMarketData();
        StartAutoRefresh();
    }

    private async Task LoadMarketData()
    {
        try
        {
            isLoading = true;
            errorMessage = "";
            marketOpen = await FyersDataService.IsMarketOpenAsync();
            
            stocks.Clear();
            var quotes = await FyersDataService.GetStockQuotesAsync(watchlistSymbols);
            stocks.AddRange(quotes);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartAutoRefresh()
    {
        refreshTimer = new Timer(async _ => {
            await LoadMarketData();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (refreshTimer is not null)
        {
            await refreshTimer.DisposeAsync();
        }
    }
}
